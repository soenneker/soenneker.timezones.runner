<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <Platforms>AnyCPU</Platforms>
        <NoWarn>$(NoWarn);1591</NoWarn>
    </PropertyGroup>

    <PropertyGroup>
        <Description>Automatically updates the Soenneker.TimeZones.Data package</Description>
        <Version Condition="'$(BUILD_VERSION)' == ''">4.0.0</Version>
        <Version Condition="'$(BUILD_VERSION)' != ''">$(BUILD_VERSION)</Version>
        <AssemblyName>Soenneker.TimeZones.Runner</AssemblyName>
        <Copyright>Copyright © 2026 Jake Soenneker</Copyright>
        <Authors>Jake Soenneker</Authors>
        <Company>https://soenneker.com</Company>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <IsPackable>false</IsPackable>
        <LangVersion>latest</LangVersion>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.10" />
        <PackageReference Include="Clipper2" Version="2.0.0" />
        <PackageReference Include="OsmSharp" Version="6.2.0" />
        <PackageReference Include="Soenneker.Python.Util" Version="4.0.303" />
        <PackageReference Include="Soenneker.Git.Util" Version="4.0.3608" />
        <PackageReference Include="Soenneker.GitHub.Repositories.Releases" Version="4.0.888" />
        <PackageReference Include="Soenneker.Extensions.LoggerConfiguration" Version="4.0.1292" />
<PackageReference Include="Soenneker.Utils.Dotnet.NuGet" Version="4.0.2020" />
        <PackageReference Include="Soenneker.Utils.Environment" Version="4.0.682" />
<PackageReference Include="Soenneker.Utils.File.Download" Version="4.0.1644" />
</ItemGroup>
</Project>
